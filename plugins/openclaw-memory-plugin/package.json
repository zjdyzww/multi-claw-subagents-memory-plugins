{
  "name": "@multi-claw/openclaw-memory-plugin",
  "version": "13.0.0",
  "description": "OpenClaw memory plugin for multi-agent memory management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "id": "openclaw-memory-plugin",
    "skills": [
      "skills/openclaw-memory-skill"
    ]
  },
  "scripts": {
    "build": "tsc && npm run copy:manifest && npm run copy:skills",
    "build:ts": "tsc",
    "copy:manifest": "cp openclaw.plugin.json dist/",
    "copy:skills": "rm -rf dist/skills && cp -r skills dist/skills",
    "dev": "tsc --watch",
    "prepublish": "npm run build"
  },
  "dependencies": {
    "@multi-claw/shared-memory-core": "file:../shared-memory-core",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
